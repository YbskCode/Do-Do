# Local development against Railway MySQL (optional — only if running backend locally)
# Get these from Railway → MySQL → Connect (public URL)
DB_HOST=your-host.proxy.rlwy.net
DB_PORT=your-port
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=railway
JWT_SECRET=same-secret-as-railway-backend

